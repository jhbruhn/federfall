<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Flutter's template only adds this to the debug/profile manifests (for
         the VM service) — federfall is online-only (every read/write is a
         network call to PocketBase, see federfall-online-only-no-cache
         memory), so a release build needs it declared here explicitly or the
         OS blocks all networking outright, surfacing as an instant "server
         unreachable" regardless of whether the server is actually up. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Find-location map picker: centre the map on the user's position. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Local medication-due reminders (federfall-3uz): runtime notification
         permission (Android 13+) and rescheduling after a reboot. Reminders
         are scheduled inexact on purpose (no SCHEDULE_EXACT_ALARM): exact
         delivery would drag the user through the "Alarms & reminders"
         settings page for no clinical gain. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- federfall-i0wq: receipt-printer connectivity (unified_esc_pos_printer).
         ACCESS_FINE_LOCATION/ACCESS_COARSE_LOCATION are already declared above
         unscoped (map picker), which also covers legacy Bluetooth scanning on
         API <= 30 — no separate maxSdkVersion="30" copies needed for that. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <!-- neverForLocation: this app's BLE scan only looks for printers, never
         derives physical location from scan results (unlike the unscoped
         ACCESS_FINE_LOCATION above, which is for the actual GPS map picker). -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />
    <application
        android:label="${appName}"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false">
        <!-- federfall-69fs: the server is the sole source of truth (online-only,
             no local cache — federfall-online-only-no-cache); Auto Backup /
             device transfer would otherwise copy flutter_cache_manager's SQLite
             cache-object catalog and shared_preferences outside PocketBase's
             access control. Nothing is lost by disabling it — a fresh install
             re-syncs from the server on login. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />            
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- federfall-gdp8: the case-report QR encodes federfall://case/<caseNumber>
                 (not an https:// App Link — see case_report.pb.js's comment: this app's
                 server address is chosen per-install at runtime, so there is no single
                 fixed domain to verify an Android App Link against). Flutter's engine
                 forwards the intent's URI straight to go_router automatically (see
                 _resolveDeepLink in lib/routing/router.dart) — no plugin needed.
                 android:launchMode "singleTop" above means a link tapped while the app
                 is already running redelivers via onNewIntent instead of spawning a
                 second instance. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="federfall" android:host="case"/>
            </intent-filter>
        </activity>
        <!-- OAuth2 sign-in redirect (flutter_web_auth_2). On mobile the app uses
             the manual code-exchange flow (AuthRepository.signInWithOAuth2Code):
             the provider redirects to federfall://oauth-callback and this
             activity captures it, instead of relying on PocketBase's realtime
             channel — which Android drops when the app is backgrounded for the
             browser (the "Auth failed on first try" bug). The intent filter is
             pinned to host "oauth-callback" so it never intercepts the
             federfall://case QR deep links (host "case") handled above. The
             matching redirect URI must be whitelisted in the OAuth2 provider —
             see docs/DEPLOYMENT.md. -->
        <activity
            android:name="com.linusu.flutter_web_auth_2.CallbackActivity"
            android:exported="true"
            android:taskAffinity="">
            <intent-filter android:label="flutter_web_auth_2">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="federfall" android:host="oauth-callback"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- flutter_local_notifications: deliver OS-scheduled reminders and
             re-register them after a reboot or app update. -->
        <receiver android:exported="false" android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver" />
        <receiver android:exported="false" android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
