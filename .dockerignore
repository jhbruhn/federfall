# Build context for the single-container image (root Dockerfile) is the repo
# root: the Flutter web build needs apps/ + packages/, and the backend stage
# bakes in backend/pocketbase/pb_migrations + pb_hooks. Keep the context lean.
.git
.github
.beads
docs
deploy

# Generated / build outputs — regenerated inside the image.
**/build/
**/.dart_tool/
**/coverage/
**/.flutter-plugins-dependencies

# Native platforms — not needed for a web build.
apps/federfall/android
apps/federfall/ios

# Tests, IDE, local cruft.
**/test/
**/.idea
**/.vscode
*.iml
docker-compose*.yml

# Backend: bake migrations + hooks ONLY. Never ship runtime state or non-image
# files (the migrations + hooks dirs are intentionally NOT ignored).
backend/pocketbase/pb_data/
backend/pocketbase/tests/
backend/pocketbase/README.md
