# ─── Beads / Dolt (issue tracker) ───────────────────────────────────────────
.dolt/
*.db
.beads-credential-key

# ─── Secrets ────────────────────────────────────────────────────────────────
# This project does NOT use .env files (config is literal in compose / JSON
# dart-defines). These lines are purely defensive in case a tool drops one.
.env
.env.*
*.pem
**/android/key.properties
**/android/app/*.jks
**/android/app/*.keystore

# ─── Dart / Flutter ─────────────────────────────────────────────────────────
.dart_tool/
.packages
.pub-cache/
.pub/
build/
.flutter-plugins
.flutter-plugins-dependencies
coverage/
doc/api/

# Generated code (freezed / json_serializable / riverpod / mocks) — regenerated
# via `dart run build_runner build`; CI does this. Not committed.
*.g.dart
*.freezed.dart
*.mocks.dart
*.config.dart

# Note: pubspec.lock IS committed (this repo ships an app — pin dependencies).

# ─── Flutter: platform-generated artefacts ──────────────────────────────────
**/android/.gradle/
**/android/captures/
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Pods/
**/ios/.symlinks/
**/ios/Runner/GeneratedPluginRegistrant.*
**/macos/Flutter/GeneratedPluginRegistrant.swift
**/macos/Pods/
**/windows/flutter/generated_plugin_registrant.*
**/linux/flutter/generated_plugin_registrant.*
**/web/flutter_service_worker.js

# ─── PocketBase backend (containerized) ─────────────────────────────────────
# Runtime DB, uploaded files, logs (Docker volume) — never commit.
# NOTE: gitignore has no inline comments — keep the pattern on its own line.
backend/pocketbase/pb_data/

# ─── IDE / editor / OS ──────────────────────────────────────────────────────
.idea/
# Ignore .vscode contents but keep shareable run/debug + recommendations.
# Use `.vscode/*` (not `.vscode/`) so the negations below can re-include files;
# a file under a fully-ignored directory cannot be re-included. The `**` globs
# cover nested packages (e.g. apps/federfall/.vscode/).
.vscode/*
!.vscode/launch.json
!.vscode/settings.json
!.vscode/extensions.json
**/.vscode/*
!**/.vscode/launch.json
!**/.vscode/settings.json
!**/.vscode/extensions.json
*.iml
.DS_Store
Thumbs.db
*.swp
*~
